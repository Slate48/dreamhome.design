{
  "name": "TeamMember",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "show_title": {
      "type": "boolean",
      "default": true
    },
    "department": {
      "type": "string",
      "enum": [
        "Sales",
        "Cabinetry",
        "Design",
        "Estimating",
        "Engineering",
        "Project Management",
        "Countertop",
        "Management",
        "Administration"
      ]
    },
    "photo_url": {
      "type": "string"
    },
    "bio": {
      "type": "string"
    },
    "is_founder": {
      "type": "boolean",
      "default": false
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "name",
    "department"
  ]
}